{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path `$env:PLUGIN_ROOT 'scripts/roslyn-mcp.ps1') session-context\"",
            "timeout": 3,
            "statusMessage": "Loading C# semantic tooling context"
          }
        ]
      }
    ]
  }
}
